# Database — get this from Neon (https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname

# Cloudinary — get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL — set to your Vercel deployment URL
FRONTEND_URL=https://your-site.vercel.app

# Admin secret — sent as X-Admin-Key header from the frontend for all write requests.
# Generate a strong random string: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=your-very-long-random-secret-here
